APP_NAME=CoreKB
ENVIRONMENT=local
SECRET_KEY=replace-with-a-long-random-secret
ACCESS_TOKEN_EXPIRE_MINUTES=1440
BACKEND_CORS_ORIGINS=["http://localhost:5173"]

POSTGRES_USER=corekb
POSTGRES_PASSWORD=corekb
POSTGRES_DB=corekb
DATABASE_URL=postgresql+psycopg://corekb:corekb@postgres:5432/corekb

UPLOAD_DIR=/app/storage/uploads
MAX_UPLOAD_SIZE_MB=50

QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=corekb_chunks
EMBEDDING_DIMENSION=1536

LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=
LLM_CHAT_MODEL=gpt-4o-mini
LLM_EMBEDDING_MODEL=text-embedding-3-small
LLM_TIMEOUT_SECONDS=60
FLOWER_URL=http://localhost:5555

REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
FLOWER_BASIC_AUTH=admin:ChangeMe123!

DEFAULT_TOP_K=5
DEFAULT_SCORE_THRESHOLD=0.2
DEFAULT_CHUNK_SIZE=800
DEFAULT_CHUNK_OVERLAP=100
EVALUATION_KB_NAME=CoreKB Evaluation KB
EVALUATION_FIXTURES_DIR=backend/tests/evaluation/fixtures/documents
RERANK_ENABLED=false
RERANK_PROVIDER=openai_compatible
RERANK_BASE_URL=
RERANK_API_KEY=
RERANK_MODEL=
RERANK_TOP_N=20

RATE_LIMIT_ENABLED=true
RATE_LIMIT_ADMIN_MULTIPLIER=3
RATE_LIMIT_LOGIN_PER_5M=20
RATE_LIMIT_CHAT_PER_MINUTE=30
RATE_LIMIT_SEARCH_PER_MINUTE=60
RATE_LIMIT_UPLOAD_PER_MINUTE=10
RATE_LIMIT_INDEX_OPS_PER_10M=10

ALERT_ENABLED=false
ALERT_WEBHOOK_URL=
ALERT_FAILED_JOB_THRESHOLD=5
ALERT_BACKUP_FAILED_ENABLED=true

BACKUP_ENABLED=false
BACKUP_CRON=0 2 * * *
BACKUP_DIR=/app/storage/backups
BACKUP_RETENTION_DAYS=14
QDRANT_STORAGE_DIR=/qdrant/storage

OTEL_ENABLED=true
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
OTEL_SERVICE_NAME=corekb-api
OTEL_WORKER_SERVICE_NAME=corekb-worker
APM_ENABLED=true
JAEGER_URL=http://localhost:16686
LOKI_ENABLED=false
LOKI_URL=http://loki:3100

VITE_API_BASE_URL=http://localhost:8000/api
